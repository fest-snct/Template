# メールサーバー設定
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=465
SMTP_USER="your_email@gmail.com"
SMTP_PASS="your_app_password"

# メールの送受信者設定
MAIL_FROM_ADDRESS="your_email@gmail.com"
MAIL_FROM_NAME="あなたのサイト名"
MAIL_TO_ADDRESS="your_receiving_email@example.com"
MAIL_TO_NAME="あなたの名前"

BASIC_USER="ベーシック認証のユーザー名"
BASIC_PASS="ベーシック認証のパスワード"

# microCMS 設定
# 例: https://your-service.microcms.io の `your-service`
MICROCMS_SERVICE_DOMAIN=""
MICROCMS_API_KEY=""

# エンドポイント名（microCMS 側で変更した場合だけ書き換えてください）
MICROCMS_NEWS_ENDPOINT="news"
MICROCMS_STORES_ENDPOINT="stores"
MICROCMS_EVENTS_ENDPOINT="events"
